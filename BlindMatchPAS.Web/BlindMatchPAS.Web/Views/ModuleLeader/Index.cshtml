@{
    ViewData["Title"] = "Module Leader Dashboard";
}

<section class="page-card">
    <span class="soft-badge">Module Leader</span>
    <h1 class="h2 mt-3">Allocation Control Center</h1>
    <p class="text-muted">Manage research areas and oversee all supervisor-student allocations.</p>

    <div class="row g-3 my-3">
        <div class="col-md-4">
            <div class="role-card">
                <h3 class="h6 text-uppercase text-muted">Research Areas</h3>
                <p class="display-6 mb-0">@ViewData["AreasCount"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="role-card">
                <h3 class="h6 text-uppercase text-muted">Matched Allocations</h3>
                <p class="display-6 mb-0">@ViewData["MatchCount"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="role-card">
                <h3 class="h6 text-uppercase text-muted">Pending/Under Review</h3>
                <p class="display-6 mb-0">@ViewData["PendingCount"]</p>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-action="ResearchAreas">Research Area CRUD</a>
        <a class="btn btn-outline-dark" asp-action="Allocations">Allocation Oversight</a>
    </div>
</section>
