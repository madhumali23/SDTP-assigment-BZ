@model BlindMatchPAS.Web.Models.SupervisorProposalActionViewModel
@{
    ViewData["Title"] = "Anonymous Proposal";
}

<section class="page-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <span class="soft-badge">Anonymous View</span>
            <h1 class="h2 mt-2 mb-1">@Model.Proposal.Title</h1>
            <p class="mb-0"><span class="status-badge status-@Model.Proposal.Status.ToString().ToLowerInvariant()">@Model.Proposal.Status</span></p>
        </div>
        <a class="btn btn-outline-dark" asp-action="Index">Back to Dashboard</a>
    </div>

    <hr />
    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    <p class="text-muted mb-2"><strong>Research Area:</strong> @Model.Proposal.ResearchArea</p>
    <p class="text-muted mb-3"><strong>Technical Stack:</strong> @Model.Proposal.TechnicalStack</p>
    <h3 class="h5">Abstract</h3>
    <p style="white-space: pre-line;">@Model.Proposal.Abstract</p>
    <small class="text-muted">Submitted: @Model.Proposal.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>

    <div class="alert alert-warning mt-3 mb-0">
        Student identity is intentionally hidden at this stage to enforce blind matching.
    </div>

    <div class="d-flex gap-2 flex-wrap mt-4">
        @if (!Model.HasExpressedInterest)
        {
            <form asp-action="ExpressInterest" asp-route-id="@Model.Proposal.Id" method="post">
                <button type="submit" class="btn btn-primary">Express Interest</button>
            </form>
        }
        else
        {
            <span class="role-chip">Interest recorded</span>
        }

        @if (!Model.IsMatched)
        {
            <form asp-action="ConfirmMatch" asp-route-id="@Model.Proposal.Id" method="post">
                <button type="submit" class="btn btn-outline-dark">Confirm Match</button>
            </form>
        }
        else
        {
            <a class="btn btn-outline-dark" asp-action="MatchDetails" asp-route-id="@Model.Proposal.Id">View Match Details</a>
        }
    </div>
</section>
